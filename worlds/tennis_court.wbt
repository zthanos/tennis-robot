#VRML_SIM R2023b utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"

WorldInfo {
  title "Tennis Robot Ball Detection Starter"
  basicTimeStep 32
  contactProperties [
    ContactProperties {
      material1 "tennis_ball"
      material2 "court"
      bounce 0.4
      coulombFriction [
        0.9
      ]
    }
  ]
}

Viewpoint {
  orientation 0.56 0.58 0.59 2.15
  position 9.5 -14 9
}

TexturedBackground {
}

TexturedBackgroundLight {
}

DEF COURT_FLOOR Solid {
  translation 0 0 -0.01
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.08 0.34 0.25
        roughness 0.8
        metalness 0
      }
      geometry Box {
        size 26 13 0.02
      }
    }
  ]
  name "court_floor"
  contactMaterial "court"
  boundingObject Box {
    size 26 13 0.02
  }
}


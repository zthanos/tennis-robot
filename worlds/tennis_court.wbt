DEF TENNIS_NET Solid {
  translation 0 0 0.55
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.04 0.04 0.04
        transparency 0.45
        roughness 0.7
        metalness 0
      }
      geometry Box {
        size 0.06 11.2 1.1
      }
    }
  ]
  name "tennis_net"
  boundingObject Box {
    size 0.06 11.2 1.1
  }
}

DEF TENNIS_ROBOT Robot {
  translation -8 0 0.16
  rotation 0 0 1 0
  controller "ball_detector"
  children [
    DEF BODY Shape {
      appearance PBRAppearance {
        baseColor 0.12 0.13 0.16
        roughness 0.55
        metalness 0
      }
      geometry Box {
        size 0.55 0.38 0.22
      }
    }
    DEF FRONT_CAMERA Camera {
      translation 0.31 0 0.16
      rotation 0 1 0 0.16
      name "front_camera"
      width 640
      height 360
      fieldOfView 1.05
      near 0.03
      far 18
    }
    DEF CAMERA_DISPLAY Display {
      translation 0 0 -0.18
      name "camera_display"
      width 640
      height 360
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0 -0.24 -0.09
      }
      device [
        RotationalMotor {
          name "left_wheel_motor"
          maxVelocity 6.28
        }
      ]
      endPoint Solid {
        translation 0 -0.24 -0.09
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.02 0.02 0.02
              roughness 0.9
              metalness 0
            }
            geometry Cylinder {
              height 0.08
              radius 0.11
            }
          }
        ]
        name "left_wheel"
        boundingObject Cylinder {
          height 0.08
          radius 0.11
        }
        physics Physics {
          density -1
          mass 0.25
        }
      }
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0 0.24 -0.09
      }
      device [
        RotationalMotor {
          name "right_wheel_motor"
          maxVelocity 6.28
        }
      ]
      endPoint Solid {
        translation 0 0.24 -0.09
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.02 0.02 0.02
              roughness 0.9
              metalness 0
            }
            geometry Cylinder {
              height 0.08
              radius 0.11
            }
          }
        ]
        name "right_wheel"
        boundingObject Cylinder {
          height 0.08
          radius 0.11
        }
        physics Physics {
          density -1
          mass 0.25
        }
      }
    }
  ]
  name "tennis_robot"
  boundingObject Box {
    size 0.55 0.38 0.22
  }
  physics Physics {
    density -1
    mass 8
  }
}

